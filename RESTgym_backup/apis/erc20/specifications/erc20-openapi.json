          "spender": {
            "type": "string"
          },
          "value": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "ApproveAndCallRequest": {
        "type": "object",
        "properties": {
          "spender": {
            "type": "string"
          },
          "value": {
