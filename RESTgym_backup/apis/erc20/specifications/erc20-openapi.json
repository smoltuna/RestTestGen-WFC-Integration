          },
          "event": {
            "$ref": "#/components/schemas/ApprovalEventResponse"
          }
        }
      },
      "TransactionResponseTransferEventResponse": {
        "type": "object",
        "description": "Transaction response containing transfer event details",
        "properties": {
          "transactionHash": {
            "type": "string",
            "description": "Hex encoded transaction hash"
          },
          "event": {
            "$ref": "#/components/schemas/TransferEventResponse"
          }
        }
