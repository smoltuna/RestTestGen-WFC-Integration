# Root .gitignore for Tesi-RESTAPI
# OS files
.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]
*$py.class
.env
.venv
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints

# VSCode
.vscode/

# Build and distribution
build/
dist/
*.egg-info/
.eggs/

# Logs
*.log

# Coverage
.coverage
coverage.xml
htmlcov/

# Database
*.sqlite3
*.sqlite3-journal

# Results and experiment outputs
results/

# Ignore secrets
secrets.*

# Ignore node_modules if any JS tools
node_modules/

# Ignore JetBrains IDE files
.idea/

# Ignore macOS Finder files
Icon?

# Ignore backup files
*~
*.bak

# Ignore test outputs
.pytest_cache/

# Ignore pipenv/poetry/pdm lock files if not used
#Pipfile.lock
#poetry.lock
#pdm.lock

# Ignore site build
site/

# Ignore Rope, Spyder, PyCharm, etc.
.ropeproject
.spyderproject
.spyproject

# Ignore mkdocs
/site

# Ignore mypy, pytype, pyre
.mypy_cache/
.pytype/
.pyre/

# Ignore celery
celerybeat-schedule
celerybeat.pid

# Ignore Cython debug
cython_debug/
